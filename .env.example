# ===========================================
# CRAFTED STUDIO - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values

# App Configuration
NEXT_PUBLIC_APP_NAME="Crafted"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_DOMAIN="localhost"  # Use "craftedstudio.ai" in production

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Authentication (BetterAuth)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-use-openssl-rand-hex-32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional - for social login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe (Payment Processing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Anthropic (Claude AI)
ANTHROPIC_API_KEY="sk-ant-..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Your App <noreply@yourdomain.com>"

# Admin Notifications
# REQUIRED: Set this to receive admin notifications
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"

# Twilio (WhatsApp - Optional)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Firecrawl (Brand Extraction - Optional)
FIRECRAWL_API_KEY="fc-..."

# fal.ai (FLUX.2 Pro + Flux Kontext Image Generation - Optional)
FAL_KEY="your-fal-key"

# Google Gemini (AI Image Generation with Style References - Optional)
GEMINI_API_KEY="your-gemini-api-key"

# Orshot (Quick Design Generation - Optional)
ORSHOT_API_KEY="your-orshot-api-key"

# PostHog (Product Analytics, Session Replay, Feature Flags)
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="/ingest"
POSTHOG_API_KEY="phx_..."  # Server-side API key (optional — disables server events if unset)

# Upstash Redis (Rate Limiting — optional, falls back to in-memory without these)
# Create a free instance at https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Logging
LOG_LEVEL="info"  # debug, info, warn, error

# Slack Integration
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_APP_ID="your-app-id"
SLACK_CLIENT_ID="your-client-id"
SLACK_CLIENT_SECRET="your-client-secret"

# Slack Channel IDs (populated after channel creation)
SLACK_SUPERADMIN_CHANNEL_ID=""
SLACK_NEW_SIGNUPS_CHANNEL_ID=""
SLACK_ALL_TASKS_CHANNEL_ID=""
SLACK_FREELANCER_APPS_CHANNEL_ID=""
SLACK_CREDIT_PURCHASES_CHANNEL_ID=""
SLACK_PENDING_REVIEWS_CHANNEL_ID=""

# ===========================================
# PRODUCTION NOTES
# ===========================================
# 1. Never commit .env.local to version control
# 2. All STRIPE_* keys should be live keys in production
# 3. BETTER_AUTH_SECRET must be at least 32 characters
# 4. Email verification is automatically enabled in production
# 5. Set ADMIN_NOTIFICATION_EMAIL to receive alerts
