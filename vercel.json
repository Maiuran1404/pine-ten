{
  "functions": {
    "src/app/api/pdf/**/*.ts": {
      "memory": 3008,
      "maxDuration": 30
    },
    "src/app/api/screenshots/**/*.ts": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
